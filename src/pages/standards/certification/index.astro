---
import Layout from "@/layouts/showcase.astro";
import { navItems } from "@/lib/nav-items";

import Navbar from "@/components/navbar.astro";
import Hero from "@/components/hero.astro";
import TextWithImage from "@/components/text-with-image.astro";
import FeatureGrid from "@/components/feature-grid.astro";
import CTABanner from "@/components/cta-banner.astro";
import Breadcrumb from "@/components/breadcrumb.astro";
import Footer from "@/components/footer.astro";
---

<Layout
  title="SCI Self-Certification — Green Software Foundation"
  description="Self-certify that your Software Carbon Intensity (SCI) calculation conforms to ISO/IEC 21031:2024. Free, open to any organisation, with public disclosure and community review."
>
  <Navbar
    logoSrc="/assets/gsf-logo-full.svg"
    logoAlt="Green Software Foundation"
    logoHref="/"
    topBar="none"
    showSearch
    navItems={navItems}
    ctaText="Discuss your challenges"
    ctaHref="/membership/"
  />

  <Breadcrumb items={[
    { label: "Home", href: "/" },
    { label: "Standards", href: "/standards/" },
    { label: "Certification" },
  ]} />

  <!-- Hero -->
  <Hero
    heading="SCI Self-Certification"
    headingAccent="Programme"
    body="Demonstrate that your Software Carbon Intensity (SCI) calculation conforms to ISO/IEC 21031:2024. GSF reviews your disclosure for completeness and publishes it for community review. Free and open to any organisation."
    ctas={[
      { text: "Apply now", variant: "primary", href: "mailto:sci-certification@greensoftware.foundation?subject=SCI%20Self-Certification%20Submission" },
      { text: "Learn about SCI", variant: "outline", href: "/standards/sci/" },
    ]}
    imageSrc="/assets/ready.svg"
    imageAlt="SCI Certification illustration"
    bgClass="bg-accent-lightest-2"
  />

  <!-- What it is -->
  <TextWithImage
    badge="ABOUT THE PROGRAMME"
    heading="Self-certification, not"
    headingAccent="third-party audit"
    body="You declare that your SCI calculation conforms to ISO/IEC 21031:2024. GSF checks your disclosure is complete and detailed enough for the public to understand your calculation, then issues a certificate and publishes your submission. The community serves as the validation layer — any party can review your published disclosure and raise a challenge."
    ctaText="Read the SCI specification →"
    ctaHref="/standards/sci/"
    imageSrc="/assets/why-feat-1.svg"
    imageAlt="Self-certification illustration"
    bgClass="bg-white"
    reversed
  />

  <!-- How it works -->
  <FeatureGrid
    heading="How it *works*"
    body="Email your submission to sci-certification@greensoftware.foundation. The review takes 10–15 business days and certificates are valid for one year."
    variant="bordered"
    columns={4}
    features={[
      {
        title: "1. Submit",
        description: "Email your SCI calculation using the submission template. Any organisation or individual with an SCI score can apply — it's completely free.",
      },
      {
        title: "2. Review",
        description: "A reviewer checks your submission for completeness. The standard: could a knowledgeable practitioner understand and evaluate your calculation?",
      },
      {
        title: "3. Certificate",
        description: "If approved, GSF issues a certificate and badge assets. If anything is missing, you receive specific feedback and can resubmit.",
      },
      {
        title: "4. Publish",
        description: "Your submission is published to the public sci-certifications GitHub repository, enabling transparency and community review.",
      },
    ]}
    bgClass="bg-accent-lightest-2"
  />

  <!-- What you submit -->
  <FeatureGrid
    heading="What you *submit*"
    body="Your submission must cover the full SCI calculation with enough detail for a practitioner to understand and evaluate it. Use the submission template as your starting point."
    variant="bordered"
    columns={2}
    features={[
      {
        title: "Software details & boundary",
        description: "Your organisation, software description, and which components are included or excluded from the measurement boundary — with specific rationale for each.",
      },
      {
        title: "SCI score & functional unit",
        description: "Your SCI score with units (e.g. 349.63 gCO2eq per 1,000 API requests), the measurement period, and why your chosen functional unit reflects how your software scales.",
      },
      {
        title: "Energy, carbon & embodied emissions",
        description: "Breakdowns of energy (E), carbon intensity (I), and embodied emissions (M) with data sources, methods, and per-component detail. Show the full SCI formula with your numbers.",
      },
      {
        title: "Methodology & attestation",
        description: "Your overall approach, key assumptions and limitations, and a signed attestation declaring conformity with ISO/IEC 21031:2024 and consent to public disclosure.",
      },
    ]}
    bgClass="bg-white"
  />

  <!-- After approval -->
  <TextWithImage
    badge="AFTER APPROVAL"
    heading="Certificate, badge &"
    headingAccent="public disclosure"
    body="You receive a certificate with a unique ID, plus badge assets for your website and marketing materials. Your submission is published as-is to GitHub. Certificates are valid for one year — renewal requires a new submission. The badge must always include the 'self-certified' qualifier and link to your certificate."
    ctaText="Email us to apply →"
    ctaHref="mailto:sci-certification@greensoftware.foundation?subject=SCI%20Self-Certification%20Submission"
    imageSrc="/assets/about-gsf-illustration.svg"
    imageAlt="Certificate and badge illustration"
    bgClass="bg-accent-lightest-2"
  />

  <!-- CTA -->
  <CTABanner
    heading="Ready to self-certify?"
    body="Email your submission to get started. The programme is free and open to any organisation with an SCI calculation conforming to ISO/IEC 21031:2024."
    ctaText="Email us to apply"
    ctaHref="mailto:sci-certification@greensoftware.foundation?subject=SCI%20Self-Certification%20Submission"
  />

  <Footer />
</Layout>
